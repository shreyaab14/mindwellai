{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Server (Dev)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "server/index.ts"],
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Server (Prod)",
      "program": "${workspaceFolder}/dist/server/index.js",
      "env": {
        "NODE_ENV": "production"
      },
      "console": "integratedTerminal",
      "preLaunchTask": "npm: build"
    }
  ]
}

